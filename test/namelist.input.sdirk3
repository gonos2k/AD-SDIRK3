&time_control
 run_days                            = 0,
 run_hours                           = 1,
 run_minutes                         = 0,
 run_seconds                         = 0,
 start_year                          = 2025,
 start_month                         = 06,
 start_day                           = 16,
 start_hour                          = 00,
 end_year                            = 2025,
 end_month                           = 06,
 end_day                             = 16,
 end_hour                            = 01,
 interval_seconds                    = 3600,
 input_from_file                     = .true.,
 history_interval                    = 60,
 frames_per_outfile                  = 1,
 restart                             = .false.,
 restart_interval                    = 1440,
 io_form_history                     = 2,
 io_form_restart                     = 2,
 io_form_input                       = 2,
 io_form_boundary                    = 2,
/

&domains
 time_step                           = 60,
 time_step_fract_num                 = 0,
 time_step_fract_den                 = 1,
 max_dom                             = 1,
 e_we                                = 101,
 e_sn                                = 101,
 e_vert                              = 51,
 dzstretch_s                         = 1.1,
 p_top_requested                     = 5000,
 num_metgrid_levels                  = 32,
 num_metgrid_soil_levels             = 4,
 dx                                  = 10000,
 dy                                  = 10000,
 grid_id                             = 1,
 parent_id                           = 1,
 i_parent_start                      = 1,
 j_parent_start                      = 1,
 parent_grid_ratio                   = 1,
 parent_time_step_ratio              = 1,
 feedback                            = 0,
 smooth_option                       = 0,
/

&physics
 mp_physics                          = 0,
 cu_physics                          = 0,
 ra_lw_physics                       = 0,
 ra_sw_physics                       = 0,
 bl_pbl_physics                      = 0,
 sf_sfclay_physics                   = 0,
 sf_surface_physics                  = 0,
 radt                                = 0,
 bldt                                = 0,
 cudt                                = 0,
 icloud                              = 0,
 num_land_cat                        = 21,
 sf_urban_physics                    = 0,
/

&dynamics
 ! SDIRK-3 time integration
 time_integration_scheme             = 1,        ! 0=RK3, 1=SDIRK3
 
 ! SDIRK-3 Newton-Raphson parameters
 sdirk3_max_newton_iter              = 4,        ! Max Newton iterations per stage
 sdirk3_newton_tol                   = 1.e-6,    ! Newton convergence tolerance
 sdirk3_newton_tol_relax             = 1.e-5,    ! Relaxed tolerance for stages 2,3
 sdirk3_use_adaptive_tol             = .true.,   ! Adaptive tolerance
 
 ! SDIRK-3 GMRES parameters
 sdirk3_gmres_restart                = 30,       ! GMRES restart
 sdirk3_max_gmres_iter               = 50,       ! Max GMRES iterations
 sdirk3_gmres_tol                    = 1.e-4,    ! GMRES tolerance
 
 ! SDIRK-3 preconditioner
 sdirk3_precond_type                 = 1,        ! 0=none, 1=acoustic
 sdirk3_reuse_jacobian               = .true.,   ! Reuse Jacobian between stages
 
 ! SDIRK-3 performance options
 sdirk3_cache_graphs                 = .true.,   ! Cache LibTorch graphs
 sdirk3_graph_opt_level              = 2,        ! Graph optimization (0-3)
 
 ! SDIRK-3 output
 sdirk3_verbose                      = .true.,   ! Verbose output
 sdirk3_check_conservation           = .true.,   ! Check conservation
 sdirk3_print_frequency              = 10,       ! Print every N steps
 
 ! Standard dynamics options
 w_damping                           = 1,
 diff_opt                            = 1,
 km_opt                              = 4,
 diff_6th_opt                        = 0,
 diff_6th_factor                     = 0.12,
 base_temp                           = 290.,
 damp_opt                            = 0,
 zdamp                               = 5000.,
 dampcoef                            = 0.01,
 khdif                               = 0,
 kvdif                               = 0,
 non_hydrostatic                     = .true.,
 moist_adv_opt                       = 1,
 scalar_adv_opt                      = 1,
 gwd_opt                             = 0,
/

&bdy_control
 spec_bdy_width                      = 5,
 specified                           = .true.,
/

&namelist_quilt
 nio_tasks_per_group                 = 0,
 nio_groups                          = 1,
/