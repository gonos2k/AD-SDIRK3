&time_control
 run_days                            = 0,
 run_hours                           = 1,
 run_minutes                         = 0,
 run_seconds                         = 0,
 start_year                          = 0001, 0001, 0001,
 start_month                         = 01,   01,   01,
 start_day                           = 01,   01,   01,
 start_hour                          = 00,   00,   00,
 start_minute                        = 00,   00,   00,
 start_second                        = 00,   00,   00,
 end_year                            = 0001, 0001, 0001,
 end_month                           = 01,   01,   01,
 end_day                             = 01,   01,   01,
 end_hour                            = 01,   00,   00,
 end_minute                          = 00,   00,   00,
 end_second                          = 00,   00,   00,
 history_interval_m                  = 10,   60,   60,
 history_interval_s                  = 0,    60,   60,
 frames_per_outfile                  = 1000, 1000, 1000,
 restart                             = .false.,
 restart_interval                    = 10,
 io_form_history                     = 2
 io_form_restart                     = 2
 io_form_input                       = 2
 io_form_boundary                    = 2
 debug_level                         = 100
 /

 &domains
 time_step                           = 30,
 use_adaptive_time_step              = .true.,
 step_to_output_time                 = .true.,
 target_cfl                          = 1.2, 1.2, 1.2,
 max_step_increase_pct               = 5, 51, 51,
 starting_time_step                  = -1, -1, -1,
 max_time_step                       = -1, -1, -1,
 min_time_step                       = -1, -1, -1,
 adaptation_domain                   = 1,
 time_step_sound                     = 0, 4, 4,
 s_we                                = 1,     1,     1,
 e_we                                = 41,    41,    41,
 s_sn                                = 1,     1,     1,
 e_sn                                = 3,     3,     3,
 s_vert                              = 1,     1,     1,
 e_vert                              = 101,   101,   101,
 dx                                  = 2000,  100.,  100.,
 dy                                  = 2000,  100.,  100.,
 ztop                                = 16000, 10000, 10000,
 /

 &physics
 mp_physics                          = 0,     0,     0,
 ra_lw_physics                       = 0,     0,     0,
 ra_sw_physics                       = 0,     0,     0,
 radt                                = 0,     0,     0,
 sf_sfclay_physics                   = 0,     0,     0,
 sf_surface_physics                  = 0,     0,     0,
 bl_pbl_physics                      = 0,     0,     0,
 bldt                                = 0,     0,     0,
 cu_physics                          = 0,     0,     0,
 cudt                                = 0,     0,     0,
 num_land_cat                        = 24,
 /

 &dynamics
 ! Implicit scheme settings
 use_implicit_scheme                 = .true.,
 implicit_acoustic                   = .true.,
 implicit_gravity                    = .false.,
 theta_implicit                      = 0.6,
 implicit_solver_tol                 = 1.0e-6,
 implicit_solver_max_iter            = 20,
 implicit_solver_type                = 2,
 implicit_solver_precond             = 1,
 gmres_restart                       = 30,
 
 ! Automatic differentiation settings
 acoustic_ad_mode                    = 3,
 
 ! Other dynamics settings
 rk_ord                              = 3,
 diff_opt                            = 0,
 km_opt                              = 1,
 damp_opt                            = 0,
 isfflx                              = 1,
 icloud                              = 1,
 spec_zone                           = 1,
 spec_bdy_width                      = 5,
 non_hydrostatic                     = .true., .true., .true.,
 /

 &bdy_control
 periodic_x                          = .false.,.false.,.false.,
 symmetric_xs                        = .false.,.false.,.false.,
 symmetric_xe                        = .false.,.false.,.false.,
 open_xs                             = .true., .false.,.false.,
 open_xe                             = .true., .false.,.false.,
 periodic_y                          = .true., .false.,.false.,
 symmetric_ys                        = .false.,.false.,.false.,
 symmetric_ye                        = .false.,.false.,.false.,
 open_ys                             = .false.,.false.,.false.,
 open_ye                             = .false.,.false.,.false.,
 /

 &namelist_quilt
 nio_tasks_per_group = 0,
 nio_groups = 1,
 /